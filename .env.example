# Flask
SECRET_KEY=replace-with-a-long-random-value
# Manual/local override. The official Vercel integration's POSTGRES_URL is
# detected automatically and should use Supabase transaction pooling.
DATABASE_URL=postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@POOLER_HOST:6543/postgres
AUTO_CREATE_DATABASE=false

# Supabase Auth is required. The app has no local-password fallback.
AUTH_PROVIDER=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=replace-with-your-publishable-key
# Server-only key for administrator deletion/bootstrap. Never expose or commit it.
SUPABASE_SECRET_KEY=replace-with-your-secret-key
# Optional Auth-only override when Vercel's database/storage resource belongs
# to a different Supabase project. Keep all supplied override values together.
SUPABASE_AUTH_URL=
SUPABASE_AUTH_PUBLISHABLE_KEY=
SUPABASE_AUTH_SECRET_KEY=
SUPABASE_PASSWORD_REDIRECT_URL=http://localhost:5000/reset_password
SUPABASE_OAUTH_REDIRECT_URL=http://localhost:5000/auth/callback

# One-shot operational switch: creates only missing model tables under a
# PostgreSQL advisory lock. Enable for one deployment, verify, then disable.
CIPHERSPHERE_SCHEMA_BOOTSTRAP=false

# Optional bootstrap-admin defaults. Prefer passing CLI options or a secret store.
ADMIN_EMAIL=
# Exact comma-separated emails that the app must keep as administrators.
# This deployment-owned value is never derived from editable OAuth user metadata.
ADMIN_EMAILS=
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_FULL_NAME=CipherSphere Administrator

# Storage
# Local development uses disk. Set this to supabase on Vercel.
STORAGE_BACKEND=local
SUPABASE_STORAGE_BUCKET=ciphersphere-private
# Set MAX_CONTENT_LENGTH=4194304 on Vercel (4.5 MB platform body limit).
MAX_CONTENT_LENGTH=52428800
AVATAR_MAX_BYTES=5242880
VAULT_FOLDER=
TEMP_FOLDER=
AVATAR_FOLDER=
DOWNLOAD_TOKEN_TTL_SECONDS=600
SESSION_COOKIE_SECURE=true
